# Copy this file to `.env` and fill in your real values.
# Any variable prefixed with EXPO_PUBLIC_ is inlined into the JS bundle at
# build time — restart `expo start` after changing.

# ── Backend ────────────────────────────────────────────────────────
# Optional. Falls back to http://localhost:3000/api (or 10.0.2.2 on Android).
# EXPO_PUBLIC_API_BASE_URL=https://api.your-domain.com/api

# ── Google Sign-In ────────────────────────────────────────────────
# Create OAuth 2.0 Client IDs at:
#   https://console.cloud.google.com/apis/credentials
# Follow GOOGLE_LOGIN_SETUP.md for the full walkthrough.
#
# The Web client ID is also used for the Expo Go dev flow.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
